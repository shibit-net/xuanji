{
  "name": "xuanji",
  "version": "0.0.1",
  "description": "璇玑 (Xuanji) — 开源 AI 助手",
  "type": "module",
  "bin": {
    "xuanji": "./dist/index.js"
  },
  "main": "./dist/electron/main.cjs",
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:gui": "NODE_ENV=development tsx src/index.ts gui --devtools",
    "dev:bot": "tsx src/index.ts bot",
    "build": "npm run clean && npm run build:cli && npm run build:electron",
    "build:cli": "tsup src/index.ts --format esm --target esnext --outDir dist",
    "build:electron": "tsup src/adapters/electron/main.ts src/adapters/electron/preload.ts --format cjs --target node20 --outDir dist/electron --external electron && rm -rf dist/electron/ui && cp -r src/adapters/electron/ui dist/electron/ui",
    "build:watch": "npm run build:cli -- --watch",
    "dist": "npm run build && electron-builder --config src/adapters/electron/electron-builder.config.js",
    "dist:mac": "npm run build && electron-builder --mac --config src/adapters/electron/electron-builder.config.js",
    "dist:win": "npm run build && electron-builder --win --config src/adapters/electron/electron-builder.config.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run test/unit",
    "test:ui": "vitest --ui",
    "lint": "eslint src/ --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist release"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "ink": "^5.1.0",
    "openai": "^6.22.0",
    "react": "^18.3.1",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^1.6.0",
    "@vitest/ui": "^1.6.0",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "prettier": "^3.3.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^5.2.0",
    "vitest": "^1.6.0"
  },
  "keywords": [
    "ai",
    "ai-assistant",
    "cli",
    "electron",
    "desktop",
    "claude",
    "agent",
    "terminal"
  ],
  "author": "Shibit <dev@shibit.net>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/shibit/xuanji.git"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
