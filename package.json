{
  "name": "xuanji",
  "version": "0.9.0",
  "description": "璇玑 (Xuanji) — 开源 AI 助手",
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:gui": "npm run build && concurrently -n \"SRC,GUI\" -c \"cyan,green\" \"npm run build:watch\" \"wait-on dist/index.js && cd desktop && npm run dev\"",
    "build": "npm run clean && npm run build:src",
    "build:src": "tsup --entry src/index.ts --entry src/core/acp/acp-worker.ts --format esm --target esnext --outDir dist --external tree-sitter --external tree-sitter-typescript --external tree-sitter-python --external tree-sitter-java",
    "build:gui": "cd desktop && npm run build:pre && electron-builder",
    "build:gui:mac": "cd desktop && npm run build:pre && electron-builder --mac",
    "build:gui:win": "cd desktop && npm run build:pre && electron-builder --win --x64",
    "build:gui:all": "cd desktop && npm run build:pre && electron-builder --mac --win --x64",
    "build:watch": "npm run build:src -- --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run test/unit",
    "test:ui": "vitest --ui",
    "test:multi-agent:quick": "tsx tests/multi-agent/quick-test.ts",
    "test:multi-agent:full": "tsx tests/multi-agent/comprehensive-test.ts",
    "lint": "eslint src/ --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist release desktop/dist desktop/dist-electron"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^12.6.2",
    "consola": "^3.4.2",
    "debug": "^4.4.3",
    "diff": "^8.0.3",
    "fast-glob": "^3.3.3",
    "ignore": "^7.0.5",
    "node-llama-cpp": "^3.18.1",
    "openai": "^6.22.0",
    "pdf-parse": "^2.4.5",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "^18.3.1",
    "tree-sitter": "^0.21.1",
    "tree-sitter-java": "^0.21.0",
    "tree-sitter-python": "^0.21.0",
    "tree-sitter-typescript": "^0.23.2",
    "turndown": "^7.2.2",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@anthropic-ai/claude-code": "^2.1.113",
    "@types/better-sqlite3": "^7.6.13",
    "@types/debug": "^4.1.12",
    "@types/diff": "^7.0.2",
    "@types/glob": "^8.1.0",
    "@types/node": "^20.0.0",
    "@types/pino": "^7.0.4",
    "@types/react": "^18.3.0",
    "@types/turndown": "^5.0.6",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^1.6.0",
    "@vitest/ui": "^1.6.0",
    "concurrently": "^9.2.1",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "marked": "^17.0.4",
    "prettier": "^3.3.0",
    "tsconfig-paths": "^4.2.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^5.2.0",
    "vitest": "^1.6.0",
    "wait-on": "^9.0.4"
  },
  "keywords": [
    "ai",
    "ai-assistant",
    "electron",
    "desktop",
    "claude",
    "agent"
  ],
  "author": "Shibit <dev@shibit.net>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shibit/xuanji.git"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "directories": {
    "doc": "docs",
    "example": "examples",
    "test": "test"
  },
  "bugs": {
    "url": "https://github.com/shibit/xuanji/issues"
  },
  "homepage": "https://github.com/shibit/xuanji#readme",
  "optionalDependencies": {
    "@anthropic-ai/claude-code-darwin-x64": "2.1.113"
  }
}
