# dependencies
node_modules/

# build output
dist/

# environment
.env
.env.*
!.env.example

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# test coverage
coverage/

# debug logs
*.log

# project config (user-created, not tracked)
.xuanji/

# embedding models (downloaded at runtime)
models/

# design docs (process documents, not part of the project)
doc/
# superpowers specs and plans are tracked
docs/*
!docs/superpowers/

# open-source packages (managed in separate repos)
packages/

# cross-arch native module cache (generated by swap-native-modules.sh)
desktop/build/native-modules/

# Native binaries (bundled at build time)
desktop/extraResources/node/bin/
desktop/extraResources/node/node_modules/

# Build artifacts with hashes
desktop/build-resources/NoopSandboxExecutor-*.js
