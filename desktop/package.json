{
  "name": "xuanji-desktop",
  "version": "1.0.0",
  "description": "Xuanji Desktop - AI Agent Desktop Application",
  "main": "dist-electron/index.js",
  "author": "Shibit Team",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "vite",
    "preview": "vite preview",
    "rebuild": "electron-builder install-app-deps",
    "setup:python-runtime": "bash scripts/setup-python-runtime.sh",
    "build:pre": "npm run setup:python-runtime && npx concurrently \"npm run build:acp-worker\" \"npm run build:agent-bridge\" --kill-others-on-fail && rm -f dist-electron/*.js && vite build && node scripts/install-dist-deps.mjs",
    "build:copy-deps": "node scripts/copy-native-deps.cjs",
    "build:acp-worker": "cd .. && npx tsup --config tsup.config.acp-worker.ts",
    "build:agent-bridge": "tsup --config tsup.config.agent-bridge.ts",
    "build": "npm run build:pre && npm_config_build_from_source=true electron-builder",
    "build:mac": "npm run build:pre && npm_config_build_from_source=true electron-builder --mac --x64",
    "build:mac:arm64": "npm run build:pre && npm_config_build_from_source=true electron-builder --mac --arm64",
    "build:mac:universal": "npm run build:pre && npm_config_build_from_source=true electron-builder --mac --universal",
    "build:win": "npm run build:pre && npm_config_build_from_source=true electron-builder --win --x64",
    "build:all": "npm run build:pre && npm_config_build_from_source=true electron-builder --mac --win --x64",
    "postinstall": "electron-builder install-app-deps",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@dicebear/adventurer": "^9.4.2",
    "@dicebear/avataaars": "^9.4.2",
    "@dicebear/bottts-neutral": "^9.4.2",
    "@dicebear/core": "^9.4.2",
    "@dicebear/fun-emoji": "^9.4.2",
    "@dicebear/identicon": "^9.4.2",
    "@dicebear/lorelei": "^9.4.2",
    "@dicebear/notionists": "^9.4.2",
    "@milkdown/kit": "^7.20.0",
    "@milkdown/plugin-diagram": "^7.7.0",
    "@milkdown/plugin-emoji": "^7.20.0",
    "@milkdown/plugin-math": "^7.5.9",
    "@milkdown/react": "^7.20.0",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-virtual": "^3.0.4",
    "@uiw/react-codemirror": "^4.25.9",
    "@xenova/transformers": "^2.17.2",
    "axios": "^1.15.0",
    "better-sqlite3": "^12.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cytoscape": "^3.33.3",
    "cytoscape-cose-bilkent": "^4.1.0",
    "dagre": "^0.8.5",
    "fast-redact": "^3.5.0",
    "framer-motion": "^11.0.3",
    "katex": "^0.16.45",
    "lucide-react": "^0.344.0",
    "mermaid": "^11.14.0",
    "node-pty": "^1.1.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.0",
    "pino-std-serializers": "^7.0.0",
    "pngjs": "^7.0.0",
    "react": "^18.2.0",
    "react-cytoscapejs": "^2.0.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.14.1",
    "reactflow": "^11.11.4",
    "sharp": "^0.34.5",
    "sqlite-vec": "^0.1.7-alpha.2",
    "tailwind-merge": "^3.5.0",
    "yaml": "^2.8.3",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/cytoscape": "^3.21.9",
    "@types/dagre": "^0.7.54",
    "@types/node": "^20.11.19",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "electron": "^41.5.0",
    "electron-builder": "^24.9.1",
    "electron-rebuild": "^3.2.9",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "tsup": "^8.5.1",
    "typescript": "^5.3.3",
    "vite": "^5.1.3",
    "vite-plugin-electron": "^0.28.4",
    "vite-plugin-electron-renderer": "^0.14.5",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.shibit.xuanji",
    "productName": "xuanji",
    "artifactName": "xuanji-${os}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "npmRebuild": true,
    "afterPack": "scripts/after-pack.mjs",
    "files": [
      "dist/**/*",
      "dist-electron/*.js",
      "dist-electron/*.mjs",
      "dist-electron/*.css",
      "dist-electron/*.html",
      "dist-electron/assets/**",
      "build/**/*"
    ],
    "extraResources": [
      {
        "from": "dist-electron",
        "to": "dist-electron",
        "filter": [
          "*.mjs",
          "*.node",
          "node_modules/**",
          "skill-worker.js"
        ]
      },
      {
        "from": "build-resources",
        "to": "build-resources",
        "filter": [
          "*.js"
        ]
      },
      {
        "from": "../src/infrastructure/templates",
        "to": "templates"
      },
      {
        "from": "python-runtime",
        "to": "python-runtime"
      },
      {
        "from": "extraResources/node",
        "to": "node"
      }
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.icns",
      "artifactName": "xuanji-${os}-${arch}.${ext}",
      "hardenedRuntime": false
    },
    "win": {
      "target": [
        "portable",
        "zip"
      ],
      "icon": "build/icon.ico",
      "artifactName": "xuanji-${os}-${arch}.${ext}"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/icon.png"
    }
  }
}
