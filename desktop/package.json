{
  "name": "xuanji-desktop",
  "version": "0.1.0",
  "description": "Xuanji Desktop - AI Agent Desktop Application",
  "main": "dist-electron/index.js",
  "author": "Shibit Team",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc && npm run build:agent-bridge && vite build && electron-builder",
    "preview": "vite preview",
    "electron:dev": "vite",
    "electron:build": "npm run build:agent-bridge && vite build && electron-builder",
    "build:agent-bridge": "tsup --config tsup.config.agent-bridge.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@milkdown/kit": "^7.20.0",
    "@milkdown/plugin-diagram": "^7.7.0",
    "@milkdown/plugin-emoji": "^7.20.0",
    "@milkdown/plugin-math": "^7.5.9",
    "@milkdown/react": "^7.20.0",
    "@tanstack/react-virtual": "^3.0.4",
    "@uiw/react-codemirror": "^4.25.9",
    "axios": "^1.15.0",
    "better-sqlite3": "^12.6.2",
    "framer-motion": "^11.0.3",
    "katex": "^0.16.45",
    "lucide-react": "^0.344.0",
    "mermaid": "^11.14.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.14.1",
    "reactflow": "^11.11.4",
    "sqlite-vec": "^0.1.7-alpha.2",
    "yaml": "^2.8.3",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.19",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "electron": "^41.5.0",
    "electron-builder": "^24.9.1",
    "electron-rebuild": "^3.2.9",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "tsup": "^8.5.1",
    "typescript": "^5.3.3",
    "vite": "^5.1.3",
    "vite-plugin-electron": "^0.28.4",
    "vite-plugin-electron-renderer": "^0.14.5",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.shibit.xuanji",
    "productName": "Xuanji",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "!dist-electron/agent-bridge.ts"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.icns"
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/icon.png"
    }
  }
}
