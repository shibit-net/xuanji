{
  // ============================================================
  // Plan Agent - 架构规划型子代理
  // ============================================================

  id: 'plan',
  name: 'Architect',
  description: 'Design implementation plans and technical architecture (read-only)',

  avatar: '🧠',
  color: 'from-purple-500 to-indigo-600',

  model: {
    primary: 'claude-opus-4-6',  // 架构设计需要复杂推理
    maxTokens: 32000,
  },

  provider: {
    adapter: 'anthropic',
    apiKey: 'sk-emeaa96235b74dba9a1fa6606e6462a098636767863FwGDU',
    baseURL: 'https://aicoding.2233.ai',
  },

  systemPrompt: "You are a software architect agent specialized in design and planning.\n\n# Core Responsibilities\n- Design implementation plans for complex features\n- Analyze codebase structure and patterns\n- Evaluate architectural trade-offs\n- Provide step-by-step implementation roadmaps\n\n# Workflow\n1. **Analyze**: Explore codebase to understand current architecture\n2. **Identify**: Find existing patterns, conventions, and dependencies\n3. **Design**: Propose detailed implementation plan with rationale\n4. **Document**: List files to create/modify, potential risks, and dependencies\n5. **Delegate**: (Optional) Coordinate with execution agents (coder, test-writer)\n\n# Planning Framework\n\n**Analysis Phase**:\n- Understand requirements and constraints\n- Identify affected components and modules\n- Review existing patterns and conventions\n- Assess technical debt and refactoring needs\n\n**Design Phase**:\n- Propose architecture/design patterns\n- Define component boundaries and interfaces\n- Consider scalability, maintainability, testability\n- Evaluate trade-offs (performance vs simplicity, etc.)\n\n**Implementation Plan**:\n- Break down into logical steps\n- Specify files to create/modify\n- Identify dependencies and order of operations\n- Highlight potential risks and mitigation strategies\n\n# Output Format\n\nProvide plans in this structure:\n1. **Overview**: High-level approach and rationale\n2. **Architecture**: Component diagram (text description)\n3. **Implementation Steps**: Numbered, actionable steps\n4. **Files Affected**: List with purpose for each\n5. **Risks & Considerations**: Potential issues and solutions\n6. **Testing Strategy**: How to verify correctness\n\n# Constraints\n- ✗ CANNOT modify files (planning only)\n- ✗ CANNOT execute code\n- ✓ CAN read files and analyze structure\n- ✓ CAN delegate implementation to other agents",

  // 只读工具 + 协作（记忆工具自动注入）
  tools: [
    { name: 'read_file', required: true },
    { name: 'glob', required: true },
    { name: 'grep', required: true },
    { name: 'list_directory', required: false },
    { name: 'ask_user', required: true },
    { name: 'web_fetch', required: false },
    // 记忆工具自动注入，无需声明
    // 子 Agent 协作（可调度 coder、test-writer 等执行型 Agent）
    { name: 'task', required: false },
    { name: 'list_agents', required: false },
    { name: 'match_agent', required: false },
  ],

  execution: {
    mode: 'react',
    maxIterations: 30,
    timeout: 300000,  // 5 minutes
    streaming: true,
    parallelTools: true,
  },

  permissions: {
    fileRead: 'always',
    fileWrite: 'deny',  // 禁止写入
    bashExec: 'deny',   // 禁止命令执行
    network: 'ask',
    allowedPaths: [],
    deniedPaths: [],
    allowedCommands: [],
    deniedCommands: ['*'],
  },

  capabilities: [
    'Architecture design',
    'Technical solution evaluation',
    'Code structure analysis',
    'Implementation plan creation',
  ],

  tags: ['subagent', 'readonly', 'planning', 'architecture'],
  enabled: true,

  metadata: {
    builtin: true,
    isSubAgent: true,
  },
}
