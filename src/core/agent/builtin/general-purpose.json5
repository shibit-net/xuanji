{
  // ============================================================
  // General-Purpose Agent - 通用型子代理
  // ============================================================

  id: 'general-purpose',
  name: 'General Assistant',
  description: 'Versatile sub-agent for executing various general tasks',

  avatar: '🤖',
  color: 'from-gray-500 to-gray-600',

  model: {
    primary: 'claude-sonnet-4-6',
    maxTokens: 32000,
  },

  provider: {
    adapter: 'anthropic',
    apiKey: 'sk-emeaa96235b74dba9a1fa6606e6462a098636767863FwGDU',
    baseURL: 'https://aicoding.2233.ai',
  },

  systemPrompt: "You are a general-purpose sub-agent executing a specific delegated task.\n\n# Core Responsibilities\n- Execute the assigned task efficiently and completely\n- Use appropriate tools to accomplish the work\n- Report results clearly and concisely\n- Ask for clarification if task requirements are unclear\n\n# Workflow\n1. **Understand**: Read the task description carefully\n2. **Plan**: Determine which tools and steps are needed\n3. **Execute**: Perform the work systematically\n4. **Verify**: Check that the task is completed correctly\n5. **Report**: Summarize what was done and any findings\n\n# Guidelines\n- Focus on completing the specific task assigned\n- Use tools efficiently (parallel calls when possible)\n- Be thorough but avoid unnecessary work\n- If you encounter blockers, report them clearly\n- Provide actionable results, not just descriptions\n\n# Tool Usage\n- Read files before modifying them\n- Use grep/glob for searching before reading large files\n- Prefer edit_file over write_file for modifications\n- Run tests after code changes when applicable",

  tools: [
    { name: 'read_file', required: true },
    { name: 'write_file', required: true },
    { name: 'edit_file', required: true },
    { name: 'bash', required: true },
    { name: 'glob', required: true },
    { name: 'grep', required: true },
    { name: 'ask_user', required: true },
    { name: 'web_fetch', required: false },
    // 记忆工具自动注入，无需声明
    // 子 Agent 协作
    { name: 'task', required: false },
    { name: 'list_agents', required: false },
    { name: 'match_agent', required: false },
  ],

  execution: {
    mode: 'react',
    maxIterations: 15,  // 降低到 15，避免子代理过度执行
    timeout: 300000,  // 5 minutes
    streaming: true,
    parallelTools: true,
  },

  permissions: {
    fileRead: 'always',
    fileWrite: 'ask',
    bashExec: 'ask',
    network: 'ask',
    allowedPaths: [],
    deniedPaths: [],
    allowedCommands: [],
    deniedCommands: ['rm -rf /', 'dd if=', 'mkfs'],
  },

  capabilities: [
    'File read/write',
    'Command execution',
    'Code search',
    'Network access',
  ],

  tags: ['subagent', 'general', 'default'],
  enabled: true,

  metadata: {
    builtin: true,
    isSubAgent: true,
  },
}
