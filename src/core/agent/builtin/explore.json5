{
  // ============================================================
  // Explore Agent - 快速探索型子代理
  // ============================================================

  id: 'explore',
  name: '探索助手',
  description: '快速探索代码库，查找文件和信息（只读）',

  avatar: '🔍',
  color: 'from-blue-500 to-cyan-600',

  model: {
    primary: '[CC]claude-haiku-4-5-20251001',  // 使用轻量模型
    fallback: '[CC]claude-haiku-4-5-20251001',
    maxTokens: 16000,
  },

  systemPrompt: "You are a fast exploration agent.\n\nYour role:\n- Quickly search codebases using Glob and Grep\n- Find files, functions, classes, and patterns\n- Answer questions about code structure\n- Be concise and direct\n\nConstraints:\n- You CANNOT modify files (read-only mode)\n- You CANNOT execute commands\n- Focus on information gathering only\n- Return findings in a structured format",

  // 只读工具
  tools: [
    { name: 'read_file', required: true },
    { name: 'glob', required: true },
    { name: 'grep', required: true },
    { name: 'ls', required: false },
    { name: 'ask_user', required: true },
    { name: 'web_fetch', required: false },
  ],

  execution: {
    mode: 'react',
    maxIterations: 20,  // 快速任务，迭代少
    timeout: 120000,  // 2 minutes
    streaming: true,
    parallelTools: true,
  },

  permissions: {
    fileRead: 'always',
    fileWrite: 'deny',  // 禁止写入
    bashExec: 'deny',   // 禁止命令执行
    network: 'ask',
    allowedPaths: [],
    deniedPaths: [],
    allowedCommands: [],
    deniedCommands: ['*'],  // 禁止所有命令
  },

  skills: {
    builtin: ['tool-guidance'],
    custom: [],
  },

  capabilities: [
    '代码搜索',
    '文件查找',
    '模式匹配',
    '结构分析',
  ],

  tags: ['subagent', 'readonly', 'fast', 'exploration'],
  enabled: true,

  metadata: {
    builtin: true,
    isSubAgent: true,
    useLightModel: true,
  },
}
