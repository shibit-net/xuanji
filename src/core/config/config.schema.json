{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xuanji.shibit.net/config.schema.json",
  "title": "Xuanji 配置文件",
  "description": "璇玑 AI 助手配置文件格式定义",
  "type": "object",
  "properties": {
    "version": {
      "type": "string",
      "description": "配置文件版本",
      "default": "1.0"
    },
    "provider": {
      "type": "object",
      "description": "LLM Provider 配置",
      "properties": {
        "model": {
          "type": "string",
          "description": "主模型标识",
          "minLength": 1,
          "examples": ["claude-sonnet-4-5-20250929", "gpt-4o"]
        },
        "lightModel": {
          "type": "string",
          "description": "轻量模型（用于子代理/摘要等）"
        },
        "apiKey": {
          "type": "string",
          "description": "API 密钥",
          "minLength": 1
        },
        "baseURL": {
          "type": "string",
          "description": "API 基础地址",
          "pattern": "^https?://"
        },
        "adapter": {
          "type": "string",
          "description": "Provider 适配器",
          "enum": ["anthropic", "openai", "openai-responses"]
        },
        "maxTokens": {
          "type": "integer",
          "description": "最大输出 token 数",
          "minimum": 1,
          "maximum": 1000000
        },
        "temperature": {
          "type": "number",
          "description": "采样温度",
          "minimum": 0,
          "maximum": 2
        },
        "timeout": {
          "type": "integer",
          "description": "请求超时（毫秒）",
          "minimum": 1000,
          "maximum": 600000
        }
      },
      "required": ["model", "apiKey"]
    },
    "ui": {
      "type": "object",
      "description": "界面配置",
      "properties": {
        "theme": {
          "type": "string",
          "description": "主题",
          "enum": ["light", "dark", "auto"],
          "default": "auto"
        },
        "language": {
          "type": "string",
          "description": "界面语言",
          "enum": ["zh", "en"],
          "default": "en"
        },
        "showTokenUsage": {
          "type": "boolean",
          "description": "是否显示 Token 用量",
          "default": true
        },
        "showCost": {
          "type": "boolean",
          "description": "是否显示费用",
          "default": true
        },
        "showThinking": {
          "type": "boolean",
          "description": "是否显示思考过程",
          "default": false
        }
      }
    },
    "tools": {
      "type": "object",
      "description": "工具配置",
      "properties": {
        "enabled": {
          "type": "array",
          "description": "启用的工具列表",
          "items": { "type": "string" }
        },
        "schemaMode": {
          "type": "string",
          "description": "Schema 模式",
          "enum": ["compact", "detailed", "auto"],
          "default": "compact"
        },
        "permissions": {
          "type": "object",
          "description": "权限配置",
          "properties": {
            "fileWrite": {
              "type": "string",
              "enum": ["always", "ask", "never"],
              "default": "ask"
            },
            "fileRead": {
              "type": "string",
              "enum": ["always", "ask", "never"],
              "default": "always"
            },
            "bashExec": {
              "type": "string",
              "enum": ["always", "ask", "never"],
              "default": "ask"
            },
            "warnLevel": {
              "type": "string",
              "enum": ["auto-allow", "ask"],
              "default": "ask"
            },
            "confirmWrite": {
              "type": "string",
              "enum": ["ask", "auto", "plan-only"],
              "default": "plan-only"
            },
            "allowedCommands": {
              "type": "array",
              "items": { "type": "string" }
            },
            "deniedCommands": {
              "type": "array",
              "items": { "type": "string" }
            },
            "allowedPaths": {
              "type": "array",
              "items": { "type": "string" }
            },
            "deniedPaths": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "timeouts": {
          "type": "object",
          "properties": {
            "bash": {
              "type": "integer",
              "minimum": 1000,
              "default": 120000
            },
            "webFetch": {
              "type": "integer",
              "minimum": 1000,
              "default": 30000
            },
            "default": {
              "type": "integer",
              "minimum": 1000,
              "default": 300000
            },
            "backgroundTask": {
              "type": "integer",
              "minimum": 1000,
              "default": 3600000
            },
            "agent_team": {
              "type": "integer",
              "minimum": 1000,
              "default": 1800000
            },
            "task": {
              "type": "integer",
              "minimum": 1000,
              "default": 1800000
            },
            "interactive": {
              "type": "integer",
              "minimum": 1000,
              "default": 1800000
            }
          }
        }
      }
    },
    "retry": {
      "type": "object",
      "description": "重试策略",
      "properties": {
        "maxRetries": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10,
          "default": 3
        },
        "initialDelay": {
          "type": "integer",
          "minimum": 100,
          "default": 1000
        },
        "maxDelay": {
          "type": "integer",
          "minimum": 1000,
          "default": 30000
        },
        "backoffMultiplier": {
          "type": "number",
          "minimum": 1,
          "maximum": 10,
          "default": 2
        }
      }
    },
    "memory": {
      "type": "object",
      "description": "记忆系统配置",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "shortTermMaxEntries": {
          "type": "integer",
          "minimum": 10,
          "maximum": 10000,
          "default": 100
        },
        "longTermMaxEntries": {
          "type": "integer",
          "minimum": 100,
          "maximum": 100000,
          "default": 1000
        }
      }
    },
    "session": {
      "type": "object",
      "description": "会话配置",
      "properties": {
        "autoSave": {
          "type": "boolean",
          "default": true
        },
        "autoSaveInterval": {
          "type": "integer",
          "minimum": 0,
          "default": 1
        },
        "maxSessions": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000,
          "default": 50
        },
        "maxMessages": {
          "type": "integer",
          "minimum": 0,
          "default": 100
        }
      }
    },
    "webSearch": {
      "type": "object",
      "description": "Web Search 配置",
      "properties": {
        "defaultProvider": {
          "type": "string",
          "enum": ["tavily", "serper", "brave", "duckduckgo"]
        },
        "cacheTTL": {
          "type": "integer",
          "minimum": 0,
          "default": 900000
        },
        "maxResults": {
          "type": "integer",
          "minimum": 1,
          "maximum": 50,
          "default": 5
        },
        "rateLimit": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "default": 10
        }
      }
    },
    "features": {
      "type": "object",
      "description": "功能特性开关",
      "properties": {
        "dynamicToolLoading": {
          "type": "boolean",
          "default": true
        },
        "proactiveButler": {
          "type": "boolean",
          "default": false
        },
        "smartMemoryV2": {
          "type": "boolean",
          "default": false
        }
      }
    }
  }
}
